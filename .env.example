# gastos-personales — environment template
# Copy to .env and fill in the values for local development.
# Production secrets live in `fly secrets` (see the fly-deploy change).

# --- Runtime ---
# development | test | production. Defaults to development.
NODE_ENV=development

# HTTP port for the Next.js server. Defaults to 3000.
PORT=3000

# debug | info | warn | error. Defaults to info.
LOG_LEVEL=info

# --- Database ---
# PostgreSQL connection string. Local dev points at a local Postgres;
# dev/staging/prod point at Neon. Required.
# Example: postgresql://user:pass@localhost:5432/gastos_dev
DATABASE_URL=

# --- Auth.js v5 ---
# 32+ byte random string. Generate with: openssl rand -base64 32
# Auth.js uses this to sign the session cookie. Required.
AUTH_SECRET=

# Public URL of the app. Used to build OAuth callback URLs.
# Defaults to http://localhost:3000.
AUTH_URL=http://localhost:3000

# Public URL of the app, used by the Hono origin-check allowlist.
# Must share the same origin as AUTH_URL. Defaults to http://localhost:3000.
APP_URL=http://localhost:3000

# --- Google provider ---
# OAuth 2.0 client ID and secret from the Google Cloud Console
# (https://console.cloud.google.com/apis/credentials). Required for
# the Google sign-in flow. Leave blank in environments where Google
# sign-in is disabled (e.g. some CI jobs).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Argon2id ---
# 32+ byte random string used to seed the DUMMY_HASH for
# timing-equalization in the Credentials authorize() function
# (BR-AUTH-4, BR-AUTH-9). Generate with: openssl rand -base64 32
# Never logged.
ARGON2ID_DUMMY_PASSWORD=

# --- Fly.io (optional) ---
# Region the VM runs in (e.g. eze for Buenos Aires). Set automatically
# by Fly at deploy time. Leave blank locally.
FLY_REGION=
